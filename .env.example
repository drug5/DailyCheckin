# Discord Daily Self-Bot — Configuration
# Copy this file to .env and fill in your values

# Your personal Discord user token (see README for how to get it)
DISCORD_TOKEN=your_user_token_here

# The channel ID to send the message in (right-click channel → Copy Channel ID)
DISCORD_CHANNEL_ID=123456789012345678

# The message to send
DISCORD_MESSAGE=Good morning everyone! 👋

# Time window — message will be sent at a random time between these two values (24h format)
TIME_START=09:00
TIME_END=12:00
